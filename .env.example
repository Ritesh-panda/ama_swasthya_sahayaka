# 🏥 JeevanRekha — Deployment Environment Variables

# --- CORE AI (Google Gemini) ---
# Get this from Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# --- BACKEND RESILIENCE (Groq Fallback) ---
# Get this from console.groq.com
GROQ_API_KEY=your_groq_api_key

# --- DATABASE (PostgreSQL) ---
# If using Render, they provide this automatically.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=your_postgresql_url

# --- SESSION MEMORY (Redis) ---
# If using Upstash Redis
REDIS_URL=your_redis_url
UPSTASH_REDIS_REST_URL=your_upstash_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# --- SPATIAL CONTEXT (Google Maps) ---
# Required for Hospital discovery
GOOGLE_API_KEY=your_google_maps_api_key

# --- WHATSAPP CHANNEL (Twilio) ---
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

# --- HEALTH ALERTS (NewsAPI) ---
NEWS_API_KEY=your_news_api_key

# --- FRONTEND CONFIG (Vite) ---
# This is used by the React app to talk to your deployed backend
VITE_BACKEND_URL=https://jeevanrekha-backend.onrender.com
VITE_GOOGLE_API_KEY=your_google_maps_api_key
VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}
